name: Build and Deploy Next.js to Azure App Service

on:
  push:
    branches:
      - main # Change this to your default branch name if it is 'master' or 'prod'
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout source code
        uses: actions/checkout@v4

      - name: Set up Node.js runtime
        uses: actions/setup-node@v4
        with:
          node-version: '22' # Matches your Azure Node v22 LTS stack
          cache: 'npm'

      - name: Install dependencies
        run: npm ci

      - name: Compile Next.js Production Build
        run: npm run build

      - name: Package deployment artifact
        # We explicitly include the hidden .next folder and exclude node_modules to keep it light
        run: |
          zip -r release.zip . -x "node_modules/*" ".git/*" ".github/*"

      - name: Upload artifact for deployment job
        uses: actions/upload-artifact@v4
        with:
          name: nextjs-app
          path: release.zip

  deploy:
    runs-on: ubuntu-latest
    needs: build
    environment:
      name: 'Production'
      url: ${{ steps.deploy-to-webapp.outputs.webapp-url }}

    steps:
      - name: Download artifact from build job
        uses: actions/download-artifact@v4
        with:
          name: nextjs-app

      - name: Unzip artifact for deployment
        run: unzip release.zip && rm release.zip

      - name: Deploy to Azure Web App
        id: deploy-to-webapp
        uses: azure/webapps-deploy@v3
        with:
          app-name: 'pylon-energy-app' # Matches your exact Azure App Service name
          publish-profile: ${{ secrets.AZURE_WEBAPP_PUBLISH_PROFILE }}
